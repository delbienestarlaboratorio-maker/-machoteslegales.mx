{
  "name": "machotes-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:core": "turbo run build --filter=app-core",
    "build:federal": "turbo run build --filter=app-federal-1",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "build:jalisco": "turbo run build --filter=app-jalisco"
  },
  "devDependencies": {
    "turbo": "^2.8.13"
  },
  "packageManager": "npm@11.6.2"
}